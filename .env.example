# KYCtrust Environment Variables
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Site Configuration
VITE_SITE_NAME=KYCtrust
VITE_SITE_URL=https://kyctrust.com
VITE_ADMIN_EMAIL=admin@kyctrust.com

# Contact Information
VITE_WHATSAPP_NUMBER=201062453344
VITE_SUPPORT_EMAIL=support@kyctrust.com
VITE_PHONE_NUMBER=+201062453344

# Analytics (Optional)
VITE_GA_TRACKING_ID=
VITE_FACEBOOK_PIXEL_ID=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_MAINTENANCE_MODE=false
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_PWA=true

# Payment Configuration
VITE_ENABLE_CRYPTO_PAYMENTS=true
VITE_ENABLE_BANK_TRANSFERS=true
VITE_ENABLE_MOBILE_MONEY=true

# Security
VITE_ENABLE_RATE_LIMITING=true
VITE_MAX_REQUESTS_PER_MINUTE=60

# Development
VITE_DEBUG_MODE=false
VITE_SHOW_CONSOLE_LOGS=false
